# === 공공데이터포털 API ===
G2B_API_KEY=your_decoded_api_key_here
G2B_BASE_URL=https://apis.data.go.kr/1230000/ad/BidPublicInfoService

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-haiku-4-5

# === Gmail SMTP ===
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_TO=your_email@gmail.com

# === 필터링 기준 (다른 강사가 바꿀 부분) ===
KEYWORDS=디자인씽킹,AI교육,리빙랩
TARGET_SCOPE=기업,공공,대학
MIN_BUDGET=20000000
DEADLINE_WINDOW_DAYS=14

# === 강사 프로필 (AI 평가용) ===
INSTRUCTOR_PROFILE=17년 이상의 디자인씽킹 교육 훈련 전문가, 리빙랩 전문가, 퍼실리테이터, AI 교육 전문가
